<?xml version="1.0" encoding="UTF-8"?>
<site xmlns="http://maven.apache.org/SITE/2.0.0" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      xsi:schemaLocation="http://maven.apache.org/SITE/2.0.0 https://maven.apache.org/xsd/site-2.0.0.xsd"
      name="PrimeKit Challenges">

    <publishDate format="dd MMMM YYYY ZZZ" position="right"/> <!-- left, right, navigation-top, navigation-bottom, bottom. -->

    <version position="right"/>

    <skin>
        <groupId>org.apache.maven.skins</groupId>
        <artifactId>maven-fluido-skin</artifactId>
        <version>2.1.0</version>
    </skin>

    <custom>
        <fluidoSkin>
            <topBarEnabled>true</topBarEnabled>
            <sideBarEnabled>true</sideBarEnabled>
            <breadcrumbDivider>»</breadcrumbDivider>
            <navBarStyle>navbar</navBarStyle>
            <copyrightClass>pull-right</copyrightClass>
            <skipGenerationDate>false</skipGenerationDate>
            <sourceLineNumbersEnabled>true</sourceLineNumbersEnabled>
            <gitHub>
                <projectId>shortthirdman-org/PrimeKit-Challenges</projectId>
                <ribbonOrientation>right-bottom</ribbonOrientation>
                <ribbonColor>darkblue</ribbonColor>
            </gitHub>
            <twitter>
                <user>ShortThirdMan93</user>
                <showUser>true</showUser>
                <showFollowers>true</showFollowers>
            </twitter>
        </fluidoSkin>
    </custom>

    <body>
