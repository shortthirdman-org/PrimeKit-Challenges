<?xml version="1.0" encoding="ISO-8859-1"?>
<site xmlns="http://maven.apache.org/SITE/2.0.0" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      xsi:schemaLocation="http://maven.apache.org/SITE/2.0.0 https://maven.apache.org/xsd/site-2.0.0.xsd"
      name="PrimeKit Challenges">

    <skin>
        <groupId>org.apache.maven.skins</groupId>
        <artifactId>maven-fluido-skin</artifactId>
        <version>2.1.0</version>
    </skin>

    <publishDate format="dd MMMM YYYY HH:mm:ss zzzz" position="right"/> <!-- left, right, navigation-top, navigation-bottom, bottom. -->

    <version position="right"/>

    <custom>
        <fluidoSkin>
            <topBarEnabled>true</topBarEnabled>
            <sideBarEnabled>true</sideBarEnabled>
            <breadcrumbDivider>»</breadcrumbDivider>
            <navBarStyle>navbar-inverse</navBarStyle>
            <copyrightClass>pull-right</copyrightClass>

            <skipGenerationDate>false</skipGenerationDate>
            <sourceLineNumbersEnabled>true</sourceLineNumbersEnabled>
            <gitHub>
                <projectId>shortthirdman-org/PrimeKit-Challenges</projectId>
                <ribbonOrientation>right-bottom</ribbonOrientation>
                <ribbonColor>darkblue</ribbonColor>
            </gitHub>
            <twitter>
                <user>ShortThirdMan93</user>
                <showUser>true</showUser>
                <showFollowers>true</showFollowers>
            </twitter>
        </fluidoSkin>
    </custom>

    <body>
        <menu name="Overview">
            <item name="Home" href="index.html"/>
            <item name="Contact" href="contact.html"/>
        </menu>

        <menu ref="reports"/>

        <menu ref="info"/>

        <menu ref="modules"/>
    </body>

    <bannerLeft>
        <!--https://maven.apache.org/images/apache-maven-project-2.png-->
        <image src="https://maven.apache.org/images/logos/maven-feather.png" alt="Maven Logo" position="left" width="120"/>
    </bannerLeft>

    <bannerRight>
        <image src="https://maven.apache.org/images/logos/maven-feather.png" alt="Maven Logo" position="right" width="120"/>
    </bannerRight>

    <poweredBy>
        <logo name="Maven" href="https://maven.apache.org/"
          target="https://maven.apache.org/images/logos/maven-feather.png"/>
    </poweredBy>
</site>